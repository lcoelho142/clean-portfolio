<file path="src/pages/home/HomeSidebar.css">
.frog-wrapper {
    position: relative;
    width: 75px;
    height: 75px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 0.2rem;
}

/* Theme Toggles (Keep these as they were) */
.dark-only { display: none !important; }
[data-theme='dark'] .dark-only { display: block !important; }
[data-theme='dark'] .light-only { display: none !important; }

.status-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px; /* This creates a consistent "buffer" zone */
}

.status-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 0px;
}

.mini-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    /* Standard smooth transition for everything */
    transition: all var(--color-fade);
    pointer-events: none;
}

.sun-frog {
    opacity: 0;
    z-index: 2;
}

.sun-frog.visible {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1); /* Matches base scale */
}

.sun-frog.visible {
    opacity: 1;
}

.base-frog {
    opacity: 1;
    z-index: 1;
}

.status-link:hover .base-frog {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.1); /* Subtle scale up */
}

.status-link:hover .mini-icon {
    transform: translate(-50%, -55%) scale(1.15); /* -55% nudges it up slightly more on hover */
}

.status-link:hover .stat-value {
    color: var(--hover);
    transition: var(--color-fade);
}

.status-link:active .stat-value {
    color: var(--accent);
    transition: var(--color-fade);
}

.stat-value {
    color: var(--accent);
    margin-top: 10px; 
}

.degree-unit {
    vertical-align: top;
    display: inline-block;
    margin-top: 2px;
    margin-left: 2px;
}
</file>

