@import "tailwindcss";

/* Light Mode (Default) */
:root {
  --bg-color: #fbf5eb;
  --accent: #6E79B7;
  --text-main: #1C1C1C;
  --hover: #eb6d32;
  --font-jakarta: 'Plus Jakarta Sans Variable', sans-serif;
  --font-jetbrains: 'JetBrains Mono Variable', monospace;
  --standard-radius: 12px;
  --border-thin: 1px solid #1C1C1C;
  --border-thick: 2px solid #1C1C1C;
  /* Base size: Usually 16px */
  --text-base: 1rem; 
  --base-padding: 50px;
  --color-fade: 0.3s ease-in-out;
  min-height: 100vh;
}

/* Sizing Utilities */
.text-xs   { font-size: 0.75rem;   line-height: 1rem; }    /* 12px */
.text-sm   { font-size: 0.875rem;  line-height: 1.25rem; } /* 14px */
.text-base { font-size: 1rem;      line-height: 1.5rem; }  /* 16px */
.text-lg   { font-size: 1.125rem;  line-height: 1.75rem; } /* 18px */
.text-xl   { font-size: 1.25rem;   line-height: 1.75rem; } /* 20px */
.text-2xl  { font-size: 1.5rem;    line-height: 2rem; }    /* 24px */
.text-3xl  { font-size: 1.875rem;  line-height: 2.25rem; } /* 30px */
.text-4xl  { font-size: 2.25rem;   line-height: 2.5rem; }  /* 36px */
.text-5xl  { font-size: 3rem;      line-height: 1; }       /* 48px */

/* Weight Utilities (The perfect companions) */
.font-light  { font-weight: 300; }
.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-bold   { font-weight: 700; }

.font-light-italic { font-weight: 300; font-style: italic; }
.font-normal-italic { font-weight: 400; font-style: italic; }
.font-medium-italic { font-weight: 500; font-style: italic; }
.font-bold-italic   { font-weight: 700; font-style: italic; }


.fluid-text { font-size: clamp(1.5rem, 5vw, 3rem); }
.fluid-padding { padding: clamp(1rem, 2vw, 2rem); }


body {
    font-size: var(--text-base);
    margin: 0;
    min-width: 320px;
    min-height: 100vh;
  }

.hline { 
  width: 100%;
  height: 1px;
  background: var(--text-main)
}

/* Layout Groups */
.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.stack-column {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.main-font {
  font-family: var(--font-jakarta);
  color: var(--text-main);
}

.secondary-font {
  font-family: var(--font-jetbrains);
  color: var(--text-main);
}

.accent-color {
  color: var(--accent);
}

/* Decoration Groups */
.card-shadow {
  background-color: white;
  border-radius: 8px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  padding: 30px;
}




@media (max-width: 1024px) {
